---
import { getCollection, render } from 'astro:content'
import PostLayout from '../layouts/PostLayout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ id, data }) => {
    return id.startsWith('ko/') && (import.meta.env.DEV || !data.draft)
  })

  return posts.map((post) => {
    // ko/slug/index.md → slug
    const slug = post.id.replace('ko/', '')
    return {
      params: { slug },
      props: { post },
    }
  })
}

interface Props {
  post: Awaited<ReturnType<typeof getCollection>>[number]
}

const { post } = Astro.props
const { Content } = await render(post)

// Generate excerpt for description
const excerpt = post.body?.replace(/[#*`\[\]]/g, '').slice(0, 160) || ''
---

<PostLayout
  title={post.data.title}
  description={excerpt}
  image={post.data.image}
  date={post.data.date}
  lastmod={post.data.lastmod}
  contentId={post.id}
>
  <Content />
</PostLayout>
