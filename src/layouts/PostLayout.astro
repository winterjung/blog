---
import BaseHead from '../components/BaseHead.astro'
import Giscus from '../components/Giscus.astro'
import Header from '../components/Header.astro'
import '../styles/global.css'

import type { ImageMetadata } from 'astro'

interface Props {
  title: string
  description?: string
  image?: ImageMetadata
  date: string
  lastmod?: string
  contentId?: string
}

const { title, description, image, date, lastmod, contentId } = Astro.props
const imageUrl = image?.src
const historyUrl = contentId
  ? `https://github.com/winterjung/blog/commits/main/src/content/posts/${contentId}`
  : undefined
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <BaseHead title={title} description={description} image={imageUrl} />
  </head>
  <body>
    <Header />
    <hr />
    <main>
      <article>
        <header>
          <h1>{title}</h1>
          {lastmod ? (
            <div class="dates">
              <time datetime={date}>{date}</time>
              <span class="separator">·</span>
              {historyUrl ? (
                <a href={historyUrl} class="last-edited" target="_blank" rel="noopener noreferrer">last edited {lastmod}</a>
              ) : (
                <span class="last-edited">last edited {lastmod}</span>
              )}
            </div>
          ) : (
            <time datetime={date}>{date}</time>
          )}
        </header>
        <slot />
      </article>
      <Giscus />
    </main>
    <!-- Plausible Analytics -->
    <script defer data-domain="winterjung.dev" src="https://plausible.io/js/script.js"></script>
    <!-- Heading link copy to clipboard -->
    <script>
      document.querySelectorAll('.heading-link').forEach(link => {
        link.addEventListener('click', async (e) => {
          e.preventDefault()
          const url = decodeURI(new URL(link.getAttribute('href') || '', window.location.href).href)
          await navigator.clipboard.writeText(url)

          const icon = link.querySelector('.heading-link-icon')
          if (icon) {
            const original = icon.textContent
            icon.textContent = '✓'
            setTimeout(() => { icon.textContent = original }, 1000)
          }
        })
      })
    </script>
  </body>
</html>

<style>
  article header {
    margin-bottom: 2rem;
  }

  article header h1 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  article header time,
  article header span.last-edited {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }

  article header a.last-edited {
    color: var(--color-link);
    font-size: 0.875rem;
  }

  .dates {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .separator {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
  }
</style>
