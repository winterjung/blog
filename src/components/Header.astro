---
import { getLangFromUrl, useTranslations } from '../i18n/utils'
import ThemeToggle from './ThemeToggle.astro'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

// Build language switch path based on current page
const pathname = Astro.url.pathname
const pathWithoutLang = lang === 'ko' ? pathname : pathname.replace(/^\/en/, '') || '/'
const langSwitchPath = lang === 'ko' ? `/en${pathname}` : pathWithoutLang
---

<a href={lang === 'ko' ? '/' : '/en/'}>
  <h2 class="home">winterjung blog</h2>
</a>
<nav>
  <a href={lang === 'ko' ? '/' : '/en/'}>{t('nav.posts')}</a>
  <a href={lang === 'ko' ? '/about/' : '/en/about/'}>{t('nav.about')}</a>
  <a href="/rss.xml">{t('nav.rss')}</a>
  <a href="https://github.com/winterjung" target="_blank" rel="noopener noreferrer">github</a>
  <a href="https://www.linkedin.com/in/jungwinter/" target="_blank" rel="noopener noreferrer">linkedin</a>
  <span class="utils">
    <a href={langSwitchPath}>{lang === 'ko' ? 'en' : 'ko'}</a>
    <ThemeToggle />
  </span>
</nav>

<style>
  nav a {
    text-decoration: none;
  }

  nav a:hover {
    text-decoration: underline;
  }

  nav > a::after {
    content: '·';
    margin-left: 10px;
    color: var(--color-text-secondary);
    pointer-events: none;
    text-decoration: none;
    display: inline-block;
  }

  nav > a:last-of-type::after {
    content: none;
  }

  .utils {
    margin-left: auto;
    display: flex;
    gap: 10px;
    align-items: baseline;
  }

  .utils a::after {
    content: '·';
    margin-left: 10px;
    color: var(--color-text-secondary);
    pointer-events: none;
    text-decoration: none;
    display: inline-block;
  }
</style>
